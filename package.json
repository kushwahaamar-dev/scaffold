{
  "name": "scaffold",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test",
    "contracts:deploy:sepolia": "cd contracts && forge script script/Deploy.s.sol --rpc-url base_sepolia --broadcast",
    "agent:worker": "tsx agents/worker.ts",
    "agent:verifier:server": "tsx agents/verifier-server.ts",
    "agent:verifier:client": "tsx agents/verifier-client.ts",
    "agent:demo": "tsx agents/demo-runner.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:agents": "tsc --noEmit -p tsconfig.agents.json",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.agents.json"
  },
  "devDependencies": {
    "@coinbase/cdp-sdk": "^1.48.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "jsdom": "latest",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "latest"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1044.0",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@tanstack/react-query": "^5.100.9",
    "express": "^5.2.1",
    "viem": "^2.48.8",
    "wagmi": "^2.19.5",
    "x402": "^1.2.0",
    "x402-express": "^1.2.0",
    "x402-fetch": "^1.2.0"
  }
}
