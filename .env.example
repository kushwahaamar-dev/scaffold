# ── Front-end (Vite) ─────────────────────────────────────────────────
VITE_SOLANA_CLUSTER=devnet
VITE_SOLANA_RPC=https://api.devnet.solana.com
VITE_PROGRAM_ID=4dUWewdZ6q1wXD8YxLJFrhWqqp6Gnk7TrXSD8WqDAMnG
VITE_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ── Off-chain agents (verifier / worker / demo-runner) ───────────────
# Required only if you want Gemini to score the artifact or build it.
# Get a key at https://aistudio.google.com/apikey (free tier exists).
GEMINI_API_KEY=AIza-replace-me
GEMINI_MODEL=gemini-2.5-pro

# Same Solana cluster, but used by node (no VITE_ prefix).
RPC_URL=https://api.devnet.solana.com
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Local keypair files. Generate with `solana-keygen new -o <path>`.
BUYER_KEYPAIR=/Users/amar/.config/solana/buyer.json
WORKER_KEYPAIR=/Users/amar/.config/solana/worker.json
ARBITER_KEYPAIR=/Users/amar/.config/solana/arbiter.json

# verifier.ts only needs the buyer pubkey, not the keypair.
BUYER_PUBKEY=
NONCE=1

# verifier loop knobs
SPEC=agents/spec.example.json
ARTIFACT=agents/output/index.html
TICK_MS=30000

# demo-runner knob
BUDGET_USDC=25
