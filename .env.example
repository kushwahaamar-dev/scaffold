# ─── Front-end (Vite) ────────────────────────────────────────────────
VITE_CHAIN=base-sepolia                    # or 'base'
VITE_ESCROW_ADDRESS_SEPOLIA=               # output of `forge script Deploy`
VITE_ESCROW_ADDRESS_MAINNET=
VITE_WALLETCONNECT_PROJECT_ID=             # https://cloud.reown.com — optional

# ─── Solidity / Foundry deploy ──────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...
BASESCAN_API_KEY=                          # optional, for `forge verify-contract`

# ─── Off-chain agents (Bedrock + x402 + Base) ────────────────────────
AWS_REGION=us-east-1                       # any Bedrock region
BEDROCK_MODEL=us.amazon.nova-pro-v1:0      # or anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS credentials picked up via the standard chain (~/.aws/credentials, env, or instance role)

# x402 paywall config (verifier-server.ts)
X402_PAY_TO=0x...                          # the wallet that collects per-call USDC
X402_NETWORK=base-sepolia                  # or 'base'
X402_FACILITATOR=https://x402.org/facilitator
SETTLE_ON_CHAIN=1                          # 1 = also push releaseStreamed on Base after scoring

# Base RPC + escrow
CHAIN=base-sepolia
RPC_URL=https://sepolia.base.org
SCAFFOLD_ESCROW_ADDRESS=0x...              # set after `forge script Deploy`
USDC_ADDRESS=                              # default = circle USDC for the chosen chain

# Demo runner / verifier-client identities (path or 0x... key)
BUYER_PRIVATE_KEY=0x...
WORKER_PRIVATE_KEY=0x...
ARBITER_PRIVATE_KEY=0x...
WORKER_ADDRESS=0x...                       # used by demo-runner

# verifier-client knobs
VERIFIER_URL=http://localhost:4021
JOB_ID=0x...                               # set after the buyer has called initialize
SPEC=agents/spec.example.json
ARTIFACT=agents/output/index.html
TICK_MS=30000

# demo-runner
BUDGET_USDC=25
NONCE=
PORT=4021
